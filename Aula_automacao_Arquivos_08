        "import os\n",
        "import shutil\n",
        "\n",
        "# --- Configurações Iniciais ---\n",
        "\n",
        "# Define o diretório onde os arquivos bagunçados serão criados e organizados.\n",
        "# É recomendado criar um diretório temporário para evitar bagunçar sua pasta atual.\n",
        "diretorio_base = 'arquivos_baguncados'\n",
        "\n",
        "# Lista de extensões que queremos organizar. Você pode adicionar mais aqui.\n",
        "extensoes_alvo = ['.pdf', '.jpg', '.xls', '.doc', '.py', '.txt', '.png', '.ipynb']\n",
        "\n",
        "# Número de arquivos de exemplo para criar para cada extensão.\n",
        "num_arquivos_por_tipo = 10\n",
        "\n",
        "# --- Função para criar arquivos de exemplo ---\n",
        "def criar_arquivos_exemplo(diretorio, extensoes, num_arquivos):\n",
        "    # Garante que o diretório base exista\n",
        "    os.makedirs(diretorio, exist_ok=True)\n",
        "    print(f\"Criando {num_arquivos} arquivos de exemplo para cada extensão em '{diretorio}'...\")\n",
        "    for ext in extensoes:\n",
        "        for i in range(1, num_arquivos + 1):\n",
        "            nome_arquivo = f\"arquivo_{ext[1:]}_{i}{ext}\"\n",
        "            caminho_completo = os.path.join(diretorio, nome_arquivo)\n",
        "            try:\n",
        "                with open(caminho_completo, 'w') as f:\n",
        "                    f.write(f\"Conteúdo de {nome_arquivo}\")\n",
        "                # print(f\"  Criado: {nome_arquivo}\")\n",
        "            except IOError as e:\n",
        "                print(f\"Erro ao criar o arquivo {nome_arquivo}: {e}\")\n",
        "    print(\"Criação de arquivos de exemplo concluída.\\n\")\n",
        "\n",
        "# --- Função para organizar arquivos ---\n",
        "def organizar_arquivos(diretorio_origem, extensoes):\n",
        "    print(f\"Iniciando a organização de arquivos em '{diretorio_origem}'...\")\n",
        "\n",
        "    # Lista todos os itens (arquivos e pastas) no diretório de origem\n",
        "    itens = os.listdir(diretorio_origem)\n",
        "\n",
        "    # Filtra apenas os arquivos (ignorando subdiretórios)\n",
        "    arquivos = [f for f in itens if os.path.isfile(os.path.join(diretorio_origem, f))]\n",
        "\n",
        "    if not arquivos:\n",
        "        print(\"Nenhum arquivo encontrado para organizar.\\n\")\n",
        "        return\n",
        "\n",
        "    for arquivo in arquivos:\n",
        "        # Constrói o caminho completo do arquivo atual\n",
        "        caminho_arquivo_origem = os.path.join(diretorio_origem, arquivo)\n",
        "\n",
        "        # Obtém a extensão do arquivo em letras minúsculas para padronização\n",
        "        _, extensao = os.path.splitext(arquivo)\n",
        "        extensao = extensao.lower()\n",
        "\n",
        "        # Verifica se a extensão está na nossa lista de alvos\n",
        "        if extensao in extensoes:\n",
        "            # Define o nome do diretório de destino (ex: 'PDF_Files')\n",
        "            diretorio_destino_nome = f\"{extensao[1:].upper()}_Files\"\n",
        "            caminho_diretorio_destino = os.path.join(diretorio_origem, diretorio_destino_nome)\n",
        "\n",
        "            # Cria o diretório de destino se ele não existir\n",
        "            os.makedirs(caminho_diretorio_destino, exist_ok=True)\n",
        "\n",
        "            # Constrói o caminho completo para onde o arquivo será movido\n",
        "            caminho_arquivo_destino = os.path.join(caminho_diretorio_destino, arquivo)\n",
        "\n",
        "            try:\n",
        "                # Move o arquivo para o novo diretório\n",
        "                shutil.move(caminho_arquivo_origem, caminho_arquivo_destino)\n",
        "                print(f\"  Movido '{arquivo}' para '{diretorio_destino_nome}/'\")\n",
        "            except shutil.Error as e:\n",
        "                print(f\"Erro ao mover '{arquivo}': {e}\")\n",
        "            except Exception as e:\n",
        "                print(f\"Ocorreu um erro inesperado ao mover '{arquivo}': {e}\")\n",
        "        else:\n",
        "            # Ignora arquivos com extensões não especificadas\n",
        "            print(f\"  Ignorando '{arquivo}' (extensão '{extensao}' não está na lista alvo).\")\n",
        "    print(\"Organização de arquivos concluída.\\n\")\n",
        "\n",
        "# --- Execução Principal ---\n",
        "if __name__ == \"__main__\":\n",
        "    # 1. Cria os arquivos de exemplo no diretório base\n",
        "    criar_arquivos_exemplo(diretorio_base, extensoes_alvo, num_arquivos_por_tipo)\n",
        "\n",
        "    # 2. Organiza os arquivos criados\n",
        "    organizar_arquivos(diretorio_base, extensoes_alvo)\n",
        "\n",
        "    print(\"Verifique o diretório 'arquivos_baguncados' para ver o resultado da organização.\")\n",
        "    print(\"Você pode executar este código novamente e os arquivos já existentes serão reorganizados se estiverem fora das pastas corretas.\")\n",
        "\n",
