      "source": [
        "import random # Importa o módulo 'random' para gerar números aleatórios\n",
        "\n",
        "def verificar_temperatura():\n",
        "    # Esta função verifica a temperatura de um sistema.\n",
        "    # Permite ao usuário digitar a temperatura.\n",
        "\n",
        "    while True:\n",
        "        try:\n",
        "            # Solicita ao usuário que digite a temperatura atual.\n",
        "            temperatura_str = input(\"Digite a temperatura atual do sistema em Celsius: \")\n",
        "            temperatura_atual = float(temperatura_str)\n",
        "            break # Sai do loop se a entrada for um número válido\n",
        "        except ValueError:\n",
        "            print(\"Entrada inválida. Por favor, digite um número para a temperatura.\")\n",
        "\n",
        "    # Imprime a temperatura atual formatada com duas casas decimais.\n",
        "    print(\"Temperatura atual do sistema: \" + str(round(temperatura_atual, 2)) + \"°C\")\n",
        "\n",
        "    # Verifica se a temperatura atual excede o limite de 30°C.\n",
        "    if temperatura_atual > 30:\n",
        "        # Se a temperatura for maior que 30°C, exibe um alerta de superaquecimento.\n",
        "        print(\"ALERTA: Superaquecimento detectado! Temperatura acima de 30°C.\")\n",
        "    else:\n",
        "        # Caso contrário, informa que a temperatura do sistema está normal.\n",
        "        print(\"Temperatura do sistema está normal.\")\n",
        "\n",
        "# Chama a função para executar a verificação da temperatura.\n",
        "verificar_temperatura()\n"
      ],
