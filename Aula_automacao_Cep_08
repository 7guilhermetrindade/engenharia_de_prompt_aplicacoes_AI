      "source": [
        "import requests\n",
        "import json\n",
        "import os\n",
        "\n",
        "def consultar_cep_via_api(cep):\n",
        "    \"\"\"\n",
        "    Consulta a API pública ViaCEP para obter informações de endereço.\n",
        "    Args:\n",
        "        cep (str): O CEP a ser consultado (apenas números).\n",
        "    Returns:\n",
        "        dict: Um dicionário com os dados brutos do endereço da API, ou None em caso de erro.\n",
        "    \"\"\"\n",
        "    # Limpa o CEP, removendo quaisquer caracteres não numéricos e garantindo 8 dígitos\n",
        "    cep = ''.join(filter(str.isdigit, cep))\n",
        "\n",
        "    if len(cep) != 8:\n",
        "        print(f\"Erro: O CEP '{cep}' é inválido. Deve conter 8 dígitos numéricos.\")\n",
        "        return None\n",
        "\n",
        "    # URL da API ViaCEP\n",
        "    url = f\"https://viacep.com.br/ws/{cep}/json/\"\n",
        "\n",
        "    print(f\"Consultando CEP '{cep}' na ViaCEP...\")\n",
        "    try:\n",
        "        # Faz a requisição GET para a API\n",
        "        response = requests.get(url, timeout=10) # Adiciona um timeout de 10 segundos\n",
        "        response.raise_for_status()  # Levanta uma exceção para códigos de status HTTP de erro (4xx ou 5xx)\n",
        "\n",
        "        # Converte a resposta JSON para um dicionário Python\n",
        "        dados_endereco_bruto = response.json()\n",
        "\n",
        "        # A API ViaCEP retorna um dicionário com a chave 'erro' se o CEP não for encontrado\n",
        "        if dados_endereco_bruto.get('erro'):\n",
        "            print(f\"CEP '{cep}' não encontrado ou é inválido na base de dados da ViaCEP.\")\n",
        "            return None\n",
        "\n",
        "        return dados_endereco_bruto\n",
        "\n",
        "    except requests.exceptions.HTTPError as http_err:\n",
        "        print(f\"Erro HTTP ao consultar o CEP '{cep}': {http_err} (Status: {response.status_code}).\")\n",
        "    except requests.exceptions.ConnectionError as conn_err:\n",
        "        print(f\"Erro de Conexão ao consultar o CEP '{cep}': {conn_err}. Verifique sua conexão com a internet.\")\n",
        "    except requests.exceptions.Timeout as timeout_err:\n",
        "        print(f\"Tempo limite esgotado ao consultar o CEP '{cep}': {timeout_err}. A API demorou demais para responder.\")\n",
        "    except requests.exceptions.RequestException as req_err:\n",
        "        print(f\"Ocorreu um erro inesperado na requisição para o CEP '{cep}': {req_err}\")\n",
        "    except json.JSONDecodeError as json_err:\n",
        "        print(f\"Erro ao decodificar JSON da resposta da API para o CEP '{cep}': {json_err}. Resposta inválida.\")\n",
        "    except Exception as e:\n",
        "        print(f\"Ocorreu um erro desconhecido: {e}\")\n",
        "    return None\n",
        "\n",
        "def formatar_endereco_para_json(dados_brutos):\n",
        "    \"\"\"\n",
        "    Formata os dados brutos do endereço obtidos da API para um formato JSON limpo e legível.\n",
        "    Args:\n",
        "        dados_brutos (dict): Dicionário com os dados brutos do endereço da API.\n",
        "    Returns:\n",
        "        dict: Um dicionário formatado com as informações do endereço.\n",
        "    \"\"\"\n",
        "    if not dados_brutos:\n",
        "        return {}\n",
        "\n",
        "    # Extrai e formata as informações, tratando possíveis chaves ausentes\n",
        "    endereco_formatado = {\n",
        "        \"cep\": dados_brutos.get('cep', 'Não informado'),\n",
        "        \"logradouro\": dados_brutos.get('logradouro', 'Não informado'),\n",
        "        \"complemento\": dados_brutos.get('complemento', ''), # Complemento pode ser vazio\n",
        "        \"bairro\": dados_brutos.get('bairro', 'Não informado'),\n",
        "        \"localidade\": dados_brutos.get('localidade', 'Não informado'),\n",
        "        \"uf\": dados_brutos.get('uf', 'NI'),\n",
        "        \"ibge\": dados_brutos.get('ibge', 'Não informado'),\n",
        "        \"gia\": dados_brutos.get('gia', 'Não informado'),\n",
        "        \"ddd\": dados_brutos.get('ddd', 'Não informado'),\n",
        "        \"siafi\": dados_brutos.get('siafi', 'Não informado')\n",
        "    }\n",
        "    return endereco_formatado\n",
        "\n",
        "def salvar_endereco_em_json(dados_formatados, nome_arquivo):\n",
        "    \"\"\"\n",
        "    Salva um dicionário de dados de endereço em um arquivo JSON.\n",
        "    Args:\n",
        "        dados_formatados (dict): Dicionário com as informações do endereço formatadas.\n",
        "        nome_arquivo (str): O nome do arquivo JSON a ser criado/sobrescrito.\n",
        "    Returns:\n",
        "        bool: True se o arquivo foi salvo com sucesso, False caso contrário.\n",
        "    \"\"\"\n",
        "    if not dados_formatados:\n",
        "        print(\"Nenhum dado para salvar. O arquivo JSON não será criado.\")\n",
        "        return False\n",
        "\n",
        "    try:\n",
        "        with open(nome_arquivo, 'w', encoding='utf-8') as f:\n",
        "            # Usa json.dump para escrever o dicionário no arquivo, com indentação para legibilidade\n",
        "            json.dump(dados_formatados, f, ensure_ascii=False, indent=4)\n",
        "        print(f\"Informações do endereço salvas com sucesso em '{nome_arquivo}'.\")\n",
        "        return True\n",
        "    except IOError as io_err:\n",
        "        print(f\"Erro de I/O ao salvar o arquivo '{nome_arquivo}': {io_err}\")\n",
        "    except Exception as e:\n",
        "        print(f\"Ocorreu um erro inesperado ao salvar o arquivo JSON: {e}\")\n",
        "    return False\n",
        "\n",
        "# --- Execução Principal do Script ---\n",
        "if __name__ == \"__main__\":\n",
        "    # Solicita o CEP ao usuário\n",
        "    cep_input = input(\"Por favor, digite o CEP que deseja consultar (apenas números, ex: 01001000): \")\n",
        "\n",
        "    # 1. Consulta a API para obter os dados brutos\n",
        "    dados_brutos = consultar_cep_via_api(cep_input)\n",
        "\n",
        "    if dados_brutos:\n",
        "        # 2. Formata os dados obtidos\n",
        "        endereco_formatado = formatar_endereco_para_json(dados_brutos)\n",
        "\n",
        "        # Define o nome do arquivo JSON\n",
        "        # O nome do arquivo será baseado no CEP consultado\n",
        "        nome_arquivo_json = f\"endereco_{endereco_formatado['cep'].replace('-', '')}.json\"\n",
        "\n",
        "        # 3. Salva as informações formatadas em um arquivo JSON\n",
        "        if salvar_endereco_em_json(endereco_formatado, nome_arquivo_json):\n",
        "            print(f\"\\nConsulta e salvamento concluídos. Verifique o arquivo '{nome_arquivo_json}'.\")\n",
        "            # Opcional: Imprimir o conteúdo formatado para o console também\n",
        "            print(\"\\n--- Conteúdo do JSON salvo ---\")\n",
        "            print(json.dumps(endereco_formatado, ensure_ascii=False, indent=4))\n",
        "            print(\"------------------------------\")\n",
        "    else:\n",
        "        print(\"\\nNão foi possível processar a consulta do CEP ou obter dados válidos.\")\n"
      ],
