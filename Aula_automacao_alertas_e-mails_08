      "source": [
        "# --- Programa Autônomo de Alerta de Condição Crítica ---\n",
        "# Este programa simula um sistema de monitoramento que verifica continuamente uma condição específica.\n",
        "# Se a condição crítica for atendida (por exemplo, um valor exceder um limite), um alerta será disparado.\n",
        "# Os alertas serão simulados através de mensagens no console.\n",
        "#\n",
        "# Como funciona:\n",
        "# 1. `checar_condicao_critica()`: Esta função simula a verificação de um sistema.\n",
        "#    Para este exemplo, ela gera um número aleatório e verifica se ele ultrapassa um limite.\n",
        "# 2. `enviar_alerta_console()` / `simular_email_alerta()`: Funções que simulam o envio de alertas\n",
        "#    para o console ou como um e-mail.\n",
        "# 3. Loop Principal: O programa entra em um loop infinito, verificando a condição a cada intervalo de tempo (`time.sleep`).\n",
        "#\n",
        "# Observação: Para parar a execução do loop infinito, você precisará interromper a célula do kernel\n",
        "# (geralmente clicando no botão de parar ou no menu 'Runtime -> Interrupt execution' no Colab).\n",
        "\n",
        "import time\n",
        "import random\n",
        "from datetime import datetime\n",
        "\n",
        "# --- Configurações do Alerta ---\n",
        "TEMPO_ENTRE_VERIFICACOES_SEGUNDOS = 5 # Verifica a cada 5 segundos\n",
        "LIMITE_CRITICO = 80                 # Valor acima do qual a condição é considerada crítica\n",
        "\n",
        "# --- Funções de Alerta ---\n",
        "def checar_condicao_critica():\n",
        "    \"\"\"\n",
        "    Simula a verificação de uma condição crítica no sistema.\n",
        "    Retorna True se a condição for crítica, False caso contrário.\n",
        "    \"\"\"\n",
        "    # Exemplo: Gera um valor aleatório entre 0 e 100\n",
        "    valor_monitorado = random.randint(0, 100)\n",
        "    print(f\"[{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}] Valor monitorado: {valor_monitorado}\")\n",
        "\n",
        "    if valor_monitorado > LIMITE_CRITICO:\n",
        "        return True, valor_monitorado\n",
        "    else:\n",
        "        return False, valor_monitorado\n",
        "\n",
        "def enviar_alerta_console(mensagem):\n",
        "    \"\"\"\n",
        "    Dispara um alerta exibindo uma mensagem no console.\n",
        "    \"\"\"\n",
        "    print(f\"\\n{'='*30}\\n!!! ALERTA CRÍTICO !!!\\n{mensagem}\\n{'='*30}\\n\")\n",
        "\n",
        "def simular_email_alerta(destinatario, assunto, corpo):\n",
        "    \"\"\"\n",
        "    Simula o envio de um e-mail de alerta, imprimindo seu conteúdo no console.\n",
        "    \"\"\"\n",
        "    print(f\"\\n{'*'*40}\")\n",
        "    print(f\"EMAIL SIMULADO ENVIADO PARA: {destinatario}\")\n",
        "    print(f\"ASSUNTO: {assunto}\")\n",
        "    print(f\"\\n{corpo}\")\n",
        "    print(f\"{'*'*40}\\n\")\n",
        "\n",
        "# --- Loop Principal do Programa Autônomo ---\n",
        "print(\"Iniciando programa de monitoramento autônomo. Pressione 'Parar' para interromper.\\n\")\n",
        "\n",
        "try:\n",
        "    while True:\n",
        "        # 1. Checa a condição crítica\n",
        "        e_critico, valor_atual = checar_condicao_critica()\n",
        "\n",
        "        # 2. Se for crítico, dispara o alerta\n",
        "        if e_critico:\n",
        "            mensagem_alerta = f\"Atenção! O valor monitorado ({valor_atual}) excedeu o limite crítico de {LIMITE_CRITICO}.\"\n",
        "\n",
        "            # Alerta no console\n",
        "            enviar_alerta_console(mensagem_alerta)\n",
        "\n",
        "            # Simula e-mail de alerta\n",
        "            simular_email_alerta(\n",
        "                destinatario=\"equipe.monitoramento@example.com\",\n",
        "                assunto=\"ALERTA CRÍTICO: Limite Excedido!\",\n",
        "                corpo=f\"Prezados,\\n\\nFoi detectada uma condição crítica no sistema.\\nDetalhes: {mensagem_alerta}\\n\\nPor favor, verifiquem imediatamente.\\n\\nAtenciosamente,\\nSistema de Monitoramento\"\n",
        "            )\n",
        "\n",
        "        # 3. Aguarda o tempo configurado antes da próxima verificação\n",
        "        time.sleep(TEMPO_ENTRE_VERIFICACOES_SEGUNDOS)\n",
        "\n",
        "except KeyboardInterrupt:\n",
        "    print(\"\\nPrograma de monitoramento interrompido pelo usuário.\")\n",
        "except Exception as e:\n",
        "    print(f\"Ocorreu um erro inesperado: {e}\")\n"
      ],
