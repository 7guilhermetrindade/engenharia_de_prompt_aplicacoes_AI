      "source": [
        "# 🎯 JOGO DA FORCA (modular)\n",
        "\n",
        "import random\n",
        "\n",
        "# -------------------------------\n",
        "# 📚 Banco de palavras\n",
        "# -------------------------------\n",
        "PALAVRAS = [\"python\", \"programacao\", \"computador\", \"teclado\", \"internet\"]\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# 🔍 Função: escolher palavra\n",
        "# -------------------------------\n",
        "def escolher_palavra():\n",
        "    return random.choice(PALAVRAS)\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# 🔤 Função: verificar letra\n",
        "# -------------------------------\n",
        "def verificar_letra(letra, palavra, letras_corretas):\n",
        "    \"\"\"\n",
        "    Verifica se a letra está na palavra.\n",
        "    Atualiza a lista de letras corretas.\n",
        "    Retorna True se acertou, False se errou.\n",
        "    \"\"\"\n",
        "    if letra in palavra:\n",
        "        letras_corretas.add(letra)\n",
        "        return True\n",
        "    return False\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# 🧠 Função: mostrar palavra parcial\n",
        "# -------------------------------\n",
        "def mostrar_progresso(palavra, letras_corretas):\n",
        "    progresso = \"\"\n",
        "    for letra in palavra:\n",
        "        if letra in letras_corretas:\n",
        "            progresso += letra + \" \"\n",
        "        else:\n",
        "            progresso += \"_ \"\n",
        "    return progresso.strip()\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# 🏁 Função: verificar vitória\n",
        "# -------------------------------\n",
        "def venceu(palavra, letras_corretas):\n",
        "    return all(letra in letras_corretas for letra in palavra)\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# 🎮 Loop principal do jogo\n",
        "# -------------------------------\n",
        "def jogar():\n",
        "    palavra = escolher_palavra()\n",
        "    letras_corretas = set()\n",
        "    tentativas = 6\n",
        "\n",
        "    print(\"🎯 Bem-vindo ao Jogo da Forca!\")\n",
        "\n",
        "    while tentativas > 0:\n",
        "        print(\"\\nPalavra:\", mostrar_progresso(palavra, letras_corretas))\n",
        "        print(\"Tentativas restantes:\", tentativas)\n",
        "\n",
        "        letra = input(\"Digite uma letra: \").lower()\n",
        "\n",
        "        # Validação básica\n",
        "        if len(letra) != 1 or not letra.isalpha():\n",
        "            print(\"⚠️ Digite apenas UMA letra válida!\")\n",
        "            continue\n",
        "\n",
        "        # 🔥 Uso da função modular\n",
        "        if verificar_letra(letra, palavra, letras_corretas):\n",
        "            print(\"✅ Acertou!\")\n",
        "        else:\n",
        "            tentativas -= 1\n",
        "            print(\"❌ Errou!\")\n",
        "\n",
        "        # Verifica vitória\n",
        "        if venceu(palavra, letras_corretas):\n",
        "            print(\"\\n🎉 Parabéns! Você venceu!\")\n",
        "            print(\"Palavra:\", palavra)\n",
        "            return\n",
        "\n",
        "    # Se acabar as tentativas\n",
        "    print(\"\\n💀 Você perdeu!\")\n",
        "    print(\"A palavra era:\", palavra)\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# 🚀 Iniciar jogo\n",
        "# -------------------------------\n",
        "if __name__ == \"__main__\":\n",
        "    jogar()"
      ],
