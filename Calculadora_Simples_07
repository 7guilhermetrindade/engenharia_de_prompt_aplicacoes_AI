      "source": [
        "# ================================\n",
        "# 🧮 CALCULADORA PYTHON COMPLETA\n",
        "# ================================\n",
        "\n",
        "# Lista para armazenar histórico\n",
        "historico = []\n",
        "\n",
        "# -------------------------------\n",
        "# 🔢 Funções das operações\n",
        "# -------------------------------\n",
        "\n",
        "def somar(a, b):\n",
        "    return a + b\n",
        "\n",
        "def subtrair(a, b):\n",
        "    return a - b\n",
        "\n",
        "def multiplicar(a, b):\n",
        "    return a * b\n",
        "\n",
        "def dividir(a, b):\n",
        "    if b == 0:\n",
        "        return None\n",
        "    return a / b\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# 🛠️ Função para validar número\n",
        "# -------------------------------\n",
        "def ler_numero(mensagem):\n",
        "    while True:\n",
        "        try:\n",
        "            return float(input(mensagem))\n",
        "        except ValueError:\n",
        "            print(\"⚠️ Entrada inválida! Digite um número válido.\")\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# 🧠 Modo expressão direta\n",
        "# -------------------------------\n",
        "def calcular_expressao(expr):\n",
        "    try:\n",
        "        resultado = eval(expr)\n",
        "        historico.append(f\"{expr} = {resultado}\")\n",
        "        print(f\"✨ Resultado: {resultado}\")\n",
        "    except ZeroDivisionError:\n",
        "        print(\"❌ Erro: divisão por zero!\")\n",
        "    except:\n",
        "        print(\"⚠️ Expressão inválida!\")\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# 📜 Mostrar histórico\n",
        "# -------------------------------\n",
        "def mostrar_historico():\n",
        "    if not historico:\n",
        "        print(\"📭 Nenhuma operação realizada ainda.\")\n",
        "    else:\n",
        "        print(\"\\n📜 Histórico das operações:\")\n",
        "        for item in historico[-10:]:  # mostra últimas 10\n",
        "            print(\"➡️\", item)\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# 📋 Menu principal\n",
        "# -------------------------------\n",
        "def menu():\n",
        "    print(\"\\n\" + \"=\"*35)\n",
        "    print(\"🧮 CALCULADORA SIMPLES\")\n",
        "    print(\"=\"*35)\n",
        "    print(\"1️⃣  Somar\")\n",
        "    print(\"2️⃣  Subtrair\")\n",
        "    print(\"3️⃣  Multiplicar\")\n",
        "    print(\"4️⃣  Dividir\")\n",
        "    print(\"5️⃣  Modo expressão (ex: 5 + 3)\")\n",
        "    print(\"6️⃣  Ver histórico\")\n",
        "    print(\"7️⃣  Sair\")\n",
        "    print(\"=\"*35)\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# 🔁 Loop principal\n",
        "# -------------------------------\n",
        "while True:\n",
        "    menu()\n",
        "    opcao = input(\"👉 Escolha uma opção: \")\n",
        "\n",
        "    if opcao == \"1\":\n",
        "        a = ler_numero(\"Digite o primeiro número: \")\n",
        "        b = ler_numero(\"Digite o segundo número: \")\n",
        "        resultado = somar(a, b)\n",
        "        print(f\"✅ Resultado: {a} + {b} = {resultado}\")\n",
        "        historico.append(f\"{a} + {b} = {resultado}\")\n",
        "\n",
        "    elif opcao == \"2\":\n",
        "        a = ler_numero(\"Digite o primeiro número: \")\n",
        "        b = ler_numero(\"Digite o segundo número: \")\n",
        "        resultado = subtrair(a, b)\n",
        "        print(f\"✅ Resultado: {a} - {b} = {resultado}\")\n",
        "        historico.append(f\"{a} - {b} = {resultado}\")\n",
        "\n",
        "    elif opcao == \"3\":\n",
        "        a = ler_numero(\"Digite o primeiro número: \")\n",
        "        b = ler_numero(\"Digite o segundo número: \")\n",
        "        resultado = multiplicar(a, b)\n",
        "        print(f\"✅ Resultado: {a} × {b} = {resultado}\")\n",
        "        historico.append(f\"{a} * {b} = {resultado}\")\n",
        "\n",
        "    elif opcao == \"4\":\n",
        "        a = ler_numero(\"Digite o primeiro número: \")\n",
        "        b = ler_numero(\"Digite o segundo número: \")\n",
        "        resultado = dividir(a, b)\n",
        "\n",
        "        if resultado is None:\n",
        "            print(\"❌ Erro: não é possível dividir por zero!\")\n",
        "        else:\n",
        "            print(f\"✅ Resultado: {a} ÷ {b} = {resultado}\")\n",
        "            historico.append(f\"{a} / {b} = {resultado}\")\n",
        "\n",
        "    elif opcao == \"5\":\n",
        "        expr = input(\"Digite a expressão (ex: 10 + 5 * 2): \")\n",
        "        calcular_expressao(expr)\n",
        "\n",
        "    elif opcao == \"6\":\n",
        "        mostrar_historico()\n",
        "\n",
        "    elif opcao == \"7\":\n",
        "        print(\"👋 Encerrando a calculadora. Até mais!\")\n",
        "        break\n",
        "\n",
        "    else:\n",
        "        print(\"⚠️ Opção inválida! Escolha uma opção de 1 a 7.\")"
      ],
